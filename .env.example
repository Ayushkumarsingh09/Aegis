# Copy and configure environment variables
cp .env.example .env

# Service URLs (local development)
AEGIS_EXCHANGE_URL=http://localhost:9080
AEGIS_QUANT_URL=http://localhost:8090
AEGIS_PORTAL_URL=http://localhost:3000

# Quant platform
AEGIS_QUANT_DUCKDB_PATH=data/aegis_quant.duckdb
AEGIS_QUANT_MLFLOW_URI=sqlite:///data/mlflow.db
AEGIS_QUANT_AEGIS_EXCHANGE_URL=http://localhost:9080

# Optional API keys
AEGIS_QUANT_POLYGON_API_KEY=
AEGIS_QUANT_ALPACA_API_KEY=
AEGIS_QUANT_ALPACA_SECRET_KEY=

# Database (Docker)
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis
POSTGRES_DB=aegis_quant

# Grafana
GF_SECURITY_ADMIN_PASSWORD=aegis
